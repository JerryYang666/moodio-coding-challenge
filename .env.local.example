# Copy to .env.local and fill in NEXT_PUBLIC_FLASK_URL.

# CDN that serves the public retrieval videos/stills.
NEXT_PUBLIC_CLOUDFRONT_URL=

# Base URL of the Flask "retrieval" API (e.g. https://api.example.com).
# The browse grid calls `${NEXT_PUBLIC_FLASK_URL}/api/content` and
# `/api/properties`, proxied via the /retrieval-api/* rewrite in next.config.js.
NEXT_PUBLIC_FLASK_URL=
